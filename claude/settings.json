{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_ZOXIDE": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Agent",
      "Bash(git *)",
      "Edit(~/repos/**)",
      "Edit(~/src/**)",
      "Edit(~/work/**)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(brew install *)",
      "Bash(curl * | *)",
      "Bash(defaults write *)",
      "Bash(diskutil *)",
      "Bash(dscl *)",
      "Bash(git push -f *)",
      "Bash(git push --force *)",
      "Bash(launchctl *)",
      "Bash(networksetup *)",
      "Bash(npm install -g *)",
      "Bash(npm install --global *)",
      "Bash(osascript *)",
      "Bash(pip install *)",
      "Bash(pipx install *)",
      "Bash(security *)",
      "Bash(wget *)",
      "Read(~/.aws/**)",
      "Read(~/.docker/**)",
      "Read(~/.ssh/**)",
      "Read(**/secrets/**)",
      "Read(**/.bash_history)",
      "Read(**/.env*)",
      "Read(**/*.key)",
      "Read(**/.zsh_history)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); model=$(echo \"$input\" | jq -r '.model.display_name'); used=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty'); [ -n \"$used\" ] && echo \"$model | $used% used\" || echo \"$model\""
  }
}
