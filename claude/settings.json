{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_ZOXIDE": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Agent",
      "Bash(git *)",
      "Edit(~/src/**)",
      "Edit(~/repos/**)",
      "Edit(~/work/**)",
      "Edit(~/.claude/**)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Bash(osascript *)",
      "Bash(defaults write *)",
      "Bash(networksetup *)",
      "Bash(dscl *)",
      "Bash(diskutil *)",
      "Bash(launchctl *)",
      "Bash(security *)",
      "Bash(pass *)",
      "Bash(op *)",
      "Bash(curl * | *)",
      "Bash(wget *)",
      "Bash(git push -f *)",
      "Bash(git push --force *)",
      "Bash(brew install *)",
      "Bash(mise install *)",
      "Bash(mise use --global *)",
      "Bash(mise use -g *)",
      "Bash(uv tool install *)",
      "Bash(uv pip install *)",
      "Bash(bun install -g *)",
      "Bash(bun install --global *)",
      "Bash(npm install -g *)",
      "Bash(npm install --global *)",
      "Bash(pip install *)",
      "Bash(pipx install *)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.ssh/**)",
      "Read(**/.env*)",
      "Read(**/secrets/**)",
      "Read(**/*.key)",
      "Read(**/.zsh_history)",
      "Read(**/.bash_history)",
      "Read(~/.docker/**)"
    ],
    "ask": [
      "Bash(docker *)",
      "Bash(helm *)",
      "Bash(kubectl *)",
      "Bash(lazydocker *)",
      "Bash(orb *)"
    ]
  },
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); model=$(echo \"$input\" | jq -r '.model.display_name'); used=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty'); [ -n \"$used\" ] && echo \"$model | $used% used\" || echo \"$model\""
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "localhost",
        "127.0.0.1"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        ".",
        "~/work",
        "~/repos",
        "~/.cache",
        "~/.claude"
      ]
    },
    "excludedCommands": [
      "git",
      "docker",
      "helm",
      "kubectl",
      "lazydocker",
      "orb"
    ]
  }
}
